# Copy to directus/.env and fill in. Used by docker-compose.yml.

# --- Directus admin (created on first boot) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=set-a-strong-admin-password

# --- Postgres ---
DB_NAME=handbook
DB_USER=directus
DB_PASSWORD=directus

# --- Directus secrets (generate each: openssl rand -hex 32) ---
DIRECTUS_KEY=replace-with-random-key
DIRECTUS_SECRET=replace-with-random-secret

PUBLIC_URL=http://localhost:8055
APP_ORIGIN=http://localhost:4321

# --- Default role for auto-provisioned Google logins ---
# Create the "Reader" role first (see README), then paste its UUID here and
# restart Directus. If left blank, new Google users get no role and see nothing
# until you assign one by hand (that is fail-closed, which is fine for the POC).
READER_ROLE_ID=

# --- Google OAuth client (create in Google Cloud Console) ---
# Authorized redirect URI: http://localhost:8055/auth/login/google/callback
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
