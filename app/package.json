{
  "name": "osbr-handbook-app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --port 4321",
    "dev:edit": "node scripts/dev-edit.mjs",
    "content:agent": "node scripts/content-agent.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "test": "node --test tests/*.test.mjs",
    "guard": "node scripts/guard-no-module-client.mjs",
    "lint": "biome check src scripts tests",
    "content:seed": "node scripts/seed-content.mjs",
    "db:reset": "wrangler d1 execute handbook --local --file db/reset.sql && wrangler d1 execute handbook --local --file db/migrations/0001_init.sql && wrangler d1 execute handbook --local --file db/seed/0002_identity.sql",
    "db:deploy": "wrangler d1 execute handbook --remote --file db/migrations/0001_init.sql && wrangler d1 execute handbook --remote --file db/seed/0002_identity.sql"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.1",
    "astro": "^7.0.3",
    "github-slugger": "^2.0.0",
    "mermaid": "^11.16.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.1",
    "@cloudflare/workers-types": "^4.20260630.1",
    "@tailwindcss/vite": "^4.3.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.105.0"
  }
}
