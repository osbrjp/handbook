---
import "../styles/global.css";
import { isEditorRole, type Visitor } from "../lib/auth/visitor";

interface Props {
  title: string;
  visitor?: Visitor | null;
}
const { title, visitor = null } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
    />
    <title>{title} · OSBR Handbook</title>
    <script is:inline>
      // Apply saved light/dark theme before paint (default dark, like the original).
      try {
        document.documentElement.dataset.theme = localStorage.getItem("theme") || "dark";
      } catch (_) {}
    </script>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">
        <img class="brand-logo" src="/logo1.svg" alt="OSBR" width="32" height="32" />
        <span>The OSBR Handbook</span>
      </a>
      <div class="nav-right">
        <div class="search" id="search">
          <input
            type="search"
            id="search-input"
            class="search-input"
            placeholder="Search…"
            autocomplete="off"
            spellcheck="false"
            role="combobox"
            aria-expanded="false"
            aria-controls="search-results"
            aria-label="Search the handbook"
          />
          <div id="search-results" class="search-results" role="listbox" hidden></div>
        </div>
        <span class="nav-sep"></span>
        <nav class="nav-links">
          <a href="https://www.osbrjp.com" target="_blank" rel="noopener">OSBR ↗</a>
        </nav>
        <span class="nav-sep"></span>
        <button id="theme-toggle" class="icon-btn" type="button" aria-label="Toggle light/dark">🌙</button>
        <a
          class="icon-btn"
          href="https://github.com/osbrjp/handbook"
          target="_blank"
          rel="noopener"
          aria-label="GitHub"
        >
          <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"></path>
          </svg>
        </a>
        <span class="nav-sep"></span>
        {
          visitor ? (
            <>
              {isEditorRole(visitor.role) && <a class="nav-edit" href="/edit-pages">Editor</a>}
              <span class="who">{visitor.login}</span>
              <form method="POST" action="/api/auth/logout" class="logout-form">
                <button type="submit" class="btn-link">Sign out</button>
              </form>
            </>
          ) : (
            <a href="/api/auth/login">Sign in</a>
          )
        }
      </div>
    </header>

    <slot />

    <script is:inline>
      // Light/dark toggle — persisted.
      (function () {
        const btn = document.getElementById("theme-toggle");
        const icon = () => {
          if (btn) btn.textContent = document.documentElement.dataset.theme === "light" ? "🌙" : "☀️";
        };
        icon();
        btn?.addEventListener("click", () => {
          const next = document.documentElement.dataset.theme === "light" ? "dark" : "light";
          document.documentElement.dataset.theme = next;
          try {
            localStorage.setItem("theme", next);
          } catch (_) {}
          icon();
        });
      })();
    </script>
    <script is:inline>
      // Navbar search: debounced fetch of /api/search, dropdown of results.
      // Result DOM is built with createElement + textContent so API strings are
      // never injected as HTML (no innerHTML on untrusted data).
      (function () {
        const wrap = document.getElementById("search");
        const input = document.getElementById("search-input");
        const panel = document.getElementById("search-results");
        if (!wrap || !input || !panel) return;

        let timer = 0;
        let seq = 0;

        function close() {
          panel.hidden = true;
          panel.replaceChildren();
          input.setAttribute("aria-expanded", "false");
        }

        function showMessage(text) {
          panel.replaceChildren();
          const div = document.createElement("div");
          div.className = "search-empty";
          div.textContent = text;
          panel.appendChild(div);
          panel.hidden = false;
          input.setAttribute("aria-expanded", "true");
        }

        function render(results) {
          panel.replaceChildren();
          if (!results.length) {
            showMessage("No results");
            return;
          }
          for (const r of results) {
            const a = document.createElement("a");
            a.className = "search-hit";
            a.href = "/" + r.slug;
            a.setAttribute("role", "option");

            const title = document.createElement("span");
            title.className = "search-hit-title";
            title.textContent = r.title;
            a.appendChild(title);

            const section = document.createElement("span");
            section.className = "search-hit-section";
            section.textContent = r.section;
            a.appendChild(section);

            if (r.snippet) {
              const snip = document.createElement("span");
              snip.className = "search-hit-snippet";
              snip.textContent = r.snippet;
              a.appendChild(snip);
            }
            panel.appendChild(a);
          }
          panel.hidden = false;
          input.setAttribute("aria-expanded", "true");
        }

        async function run(q) {
          const mine = ++seq;
          try {
            const res = await fetch("/api/search?q=" + encodeURIComponent(q), {
              headers: { Accept: "application/json" },
            });
            if (mine !== seq) return; // a newer query superseded this one
            const data = res.ok ? await res.json() : { results: [] };
            render(Array.isArray(data.results) ? data.results : []);
          } catch (_) {
            if (mine === seq) showMessage("Search unavailable");
          }
        }

        input.addEventListener("input", function () {
          clearTimeout(timer);
          const q = input.value.trim();
          if (!q) {
            close();
            return;
          }
          timer = window.setTimeout(function () {
            run(q);
          }, 200);
        });

        input.addEventListener("keydown", function (e) {
          if (e.key === "Escape") {
            close();
            input.blur();
          }
        });

        // Enter on a focused result navigates (anchors do this natively); arrow
        // keys move focus between results as a nice-to-have.
        panel.addEventListener("keydown", function (e) {
          const hits = Array.from(panel.querySelectorAll(".search-hit"));
          if (!hits.length) return;
          const i = hits.indexOf(document.activeElement);
          if (e.key === "ArrowDown") {
            e.preventDefault();
            (hits[i + 1] || hits[0]).focus();
          } else if (e.key === "ArrowUp") {
            e.preventDefault();
            (hits[i - 1] || hits[hits.length - 1]).focus();
          } else if (e.key === "Escape") {
            close();
            input.focus();
          }
        });

        document.addEventListener("click", function (e) {
          if (!wrap.contains(e.target)) close();
        });
      })();
    </script>
    <script>
      if (document.querySelector(".mermaid")) {
        import("mermaid").then((m) => {
          const dark = document.documentElement.dataset.theme !== "light";
          m.default.initialize({ startOnLoad: false, theme: dark ? "dark" : "neutral" });
          m.default.run();
        });
      }
    </script>
  </body>
</html>
