---
import type { SidebarRow } from "../lib/db/pages";

interface Props {
  pages: SidebarRow[];
  current?: string;
}
const { pages, current } = Astro.props;
const sections = [...new Set(pages.map((p) => p.section))];
---

<aside class="doc-sidebar">
  {
    sections.map((section) => {
      const items = pages.filter((p) => p.section === section);
      const hasCurrent = items.some((p) => p.slug === current);
      return (
        <details class="sb-group" data-section={section} open={hasCurrent || undefined}>
          <summary class="sb-title">{section}</summary>
          {items.map((p) =>
            p.accessible ? (
              <a class={`sb-link${p.slug === current ? " active" : ""}`} href={`/${p.slug}`}>
                {p.nav_label || p.title}
                {p.visibility === "restricted" && <span class="sb-badge">🔒</span>}
              </a>
            ) : (
              <span class="sb-link sb-noaccess" title="You don't have access to this page">
                {p.nav_label || p.title}
                <span class="sb-badge">🔒 no access</span>
              </span>
            ),
          )}
        </details>
      );
    })
  }
</aside>

<script is:inline>
  // Sidebar section open-state, per browser tab (sessionStorage):
  //  - on a RELOAD: reset to the default (only the active page's section open,
  //    set server-side) so a refresh collapses everything else;
  //  - on a normal NAVIGATION: restore the sections the user had opened, so
  //    they stay open while browsing without a refresh.
  (function () {
    const KEY = "sbSections";
    const navEntry = performance.getEntriesByType("navigation")[0];
    const isReload = navEntry && navEntry.type === "reload";
    let state = {};
    if (isReload) {
      try {
        sessionStorage.removeItem(KEY);
      } catch (_) {}
    } else {
      try {
        state = JSON.parse(sessionStorage.getItem(KEY) || "{}");
      } catch (_) {}
    }
    for (const d of document.querySelectorAll(".doc-sidebar details[data-section]")) {
      const key = d.getAttribute("data-section");
      if (!isReload && state[key]) d.open = true;
      d.addEventListener("toggle", () => {
        let s = {};
        try {
          s = JSON.parse(sessionStorage.getItem(KEY) || "{}");
        } catch (_) {}
        s[key] = d.open;
        try {
          sessionStorage.setItem(KEY, JSON.stringify(s));
        } catch (_) {}
      });
    }
  })();
</script>
