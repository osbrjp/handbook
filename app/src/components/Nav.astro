---
import type { PageRecord } from "../lib/directus";

interface Props {
  pages: PageRecord[];
}
const { pages } = Astro.props;
const sections = [...new Set(pages.map((p) => p.section))];
---

<nav>
  {
    sections.map((section) => (
      <div class="nav-section">
        <h3>{section}</h3>
        <ul>
          {pages
            .filter((p) => p.section === section)
            .map((p) => (
              <li>
                <a href={`/${p.slug}`}>{p.nav_label || p.title}</a>
                {p.visibility !== "public" && (
                  <span class={`badge badge-${p.visibility}`}>{p.visibility}</span>
                )}
              </li>
            ))}
        </ul>
      </div>
    ))
  }
</nav>
