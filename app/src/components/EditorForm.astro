---
import type { PageRow } from "../lib/db/pages";
import type { Group } from "../lib/db/groups";

interface Props {
  page?: PageRow | null;
  pageGroupKeys?: string[];
  csrf: string;
  groups: Group[];
  sections: string[];
}
const { page = null, pageGroupKeys = [], csrf, groups, sections } = Astro.props;
const visibility = page?.visibility ?? "internal";
---

<div class="editor-topbar">
  <a class="btn-cancel" href="/admin">← Back without saving</a>
  {
    page && (
      <form method="POST" action="/admin/delete" class="delete-form" id="delete-form">
        <input type="hidden" name="csrf" value={csrf} />
        <input type="hidden" name="id" value={page.id} />
        <button type="submit" class="btn-danger" data-title={page.title}>
          Delete page
        </button>
      </form>
    )
  }
</div>

<form method="POST" action="/admin/save" class="editor">
  <input type="hidden" name="csrf" value={csrf} />
  {page && <input type="hidden" name="id" value={page.id} />}
  <input type="hidden" name="sort" value={page?.sort ?? 0} />

  <details class="meta-details" open>
  <summary class="meta-summary">Page settings</summary>
  <div class="editor-meta">
  <label>Title<input name="title" id="title" value={page?.title ?? ""} required /></label>
  <label>Slug
    <input name="slug" id="slug" value={page?.slug ?? ""} placeholder="auto-generated from title" />
    <small>The page's URL (lowercase, hyphens). Auto-filled from the title — edit only if you need a custom one.</small>
  </label>
  <label>Nav label<input name="nav_label" value={page?.nav_label ?? ""} /></label>
  <label>Section
    <input name="section" list="sections" value={page?.section ?? ""} required />
    <datalist id="sections">{sections.map((s) => <option value={s} />)}</datalist>
  </label>

  <fieldset class="vis">
    <legend>Who can read this</legend>
    <label><input type="radio" name="visibility" value="public" checked={visibility === "public"} /> Anyone (public)</label>
    <label><input type="radio" name="visibility" value="internal" checked={visibility === "internal"} /> Signed-in staff</label>
    <label><input type="radio" name="visibility" value="restricted" checked={visibility === "restricted"} /> Specific groups</label>
    <div class="groups">
      {groups.map((g) => (
        <label><input type="checkbox" name="groups" value={g.key} checked={pageGroupKeys.includes(g.key)} /> {g.label}</label>
      ))}
      <small>(applied only when "Specific groups" is selected)</small>
    </div>
  </fieldset>
  </div>
  </details>

  <div class="editor-grid">
    <div class="editor-pane">
      <div class="pane-title">Body (markdown)</div>
      <textarea
        name="body"
        id="body"
        placeholder="Markdown — supports ::: callouts, [[TOC]] and ```mermaid``` blocks">{page?.body ?? ""}</textarea>
    </div>
    <div class="editor-pane">
      <div class="pane-title">Live preview</div>
      <article class="prose preview-wrap" id="preview"></article>
    </div>
  </div>

  <div class="actions">
    <button type="submit" name="status" value="draft">Save draft</button>
    <button type="submit" name="status" value="published">Publish</button>
  </div>
</form>

<script>
  const body = document.getElementById("body") as HTMLTextAreaElement | null;
  const preview = document.getElementById("preview");
  let timer: ReturnType<typeof setTimeout>;
  async function render() {
    if (!body || !preview) return;
    const res = await fetch("/admin/preview", {
      method: "POST",
      headers: { "Content-Type": "text/plain" },
      body: body.value,
    });
    if (!res.ok) return;
    // Server already sanitized (rehype-sanitize) — same trust boundary as the reader page.
    preview.innerHTML = await res.text();
    if (preview.querySelector(".mermaid")) {
      const m = await import("mermaid");
      m.default.initialize({ startOnLoad: false, theme: "neutral" });
      m.default.run({ nodes: preview.querySelectorAll(".mermaid") });
    }
  }
  body?.addEventListener("input", () => {
    clearTimeout(timer);
    timer = setTimeout(render, 250);
  });

  // Auto-fill the slug from the title until the user edits the slug directly.
  const titleEl = document.getElementById("title") as HTMLInputElement | null;
  const slugEl = document.getElementById("slug") as HTMLInputElement | null;
  const slugify = (s: string) =>
    s
      .toLowerCase()
      .trim()
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/^-+|-+$/g, "");
  let slugTouched = !!slugEl?.value;
  slugEl?.addEventListener("input", () => {
    slugTouched = true;
  });
  titleEl?.addEventListener("input", () => {
    if (!slugTouched && slugEl) slugEl.value = slugify(titleEl.value);
  });

  render();

  // Confirm before deleting — destructive and irreversible.
  const deleteForm = document.getElementById("delete-form") as HTMLFormElement | null;
  deleteForm?.addEventListener("submit", (e) => {
    const title = deleteForm.querySelector("button")?.getAttribute("data-title") ?? "this page";
    if (!confirm(`Delete "${title}"? This cannot be undone.`)) e.preventDefault();
  });
</script>
