---
import type { PageRow } from "../lib/content/pages";

// Renders a list of sibling nav nodes; parents-with-children become
// collapsible <details> (chevron toggles, the label inside <summary> still
// navigates — an <a> is its own activation target, so clicking it does NOT
// toggle). Collapsed by default except the active trail. data-section joins
// the existing CollapsePersistence wiring (n: prefix avoids clashing with
// section-group keys). Depth-capped so a parent cycle (a→b→a) can't hang the
// render — beyond the cap pages simply stop nesting.
interface Props {
  items: PageRow[];
  nodes: PageRow[];
  current?: string;
  depth?: number;
}
const { items, nodes, current, depth = 0 } = Astro.props;

const kidsOf = (slug: string) =>
  items.filter((p) => p.parent === slug).sort((a, b) => a.sort - b.sort);
const inTrail = (slug: string): boolean =>
  slug === current || kidsOf(slug).some((k) => inTrail(k.slug));
// computed here, not in the template — `<=` in a template expression trips the
// Astro compiler (astro 1002: parsed as a fragment `<`)
const withinDepthCap = depth <= 3;
---

{
  withinDepthCap &&
    nodes.map((p) => {
      const kids = kidsOf(p.slug);
      const link = (
        <a class={`sb-link${p.slug === current ? " active" : ""}`} href={`/${p.slug}`}>
          {p.nav_label || p.title}
        </a>
      );
      return kids.length > 0 ? (
        <details class="sb-node" data-section={`n:${p.slug}`} open={inTrail(p.slug) || undefined}>
          <summary class="sb-node-head">
            {link}
            <span class="sb-chevron" aria-hidden="true">
              ▸
            </span>
          </summary>
          <div class="sb-subs-tree">
            <Astro.self items={items} nodes={kids} current={current} depth={depth + 1} />
          </div>
        </details>
      ) : (
        link
      );
    })
}
