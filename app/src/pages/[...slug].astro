---
import Base from "../layouts/Base.astro";
import { getPageBySlug, type PageRow } from "../lib/db/pages";
import { renderMarkdown } from "../lib/markdown";
import { setReaderCacheHeaders } from "../lib/access";

const slug = Astro.params.slug;
if (!slug) return new Response(null, { status: 404 });

let page: PageRow | null;
try {
  page = await getPageBySlug(Astro.locals.db, slug, Astro.locals.visitor);
} catch {
  // FAIL CLOSED: never render content on a backend error.
  return new Response("Service unavailable", { status: 503 });
}

// Not-found AND forbidden both return 404 — no existence signal (red-team R2).
if (!page) return new Response(null, { status: 404 });

setReaderCacheHeaders(Astro.response.headers, page.visibility);
const html = renderMarkdown(page.body);
---

<Base title={page.title} visitor={Astro.locals.visitor}>
  <article class="prose">
    <h1>{page.title}</h1>
    <Fragment set:html={html} />
  </article>
</Base>
