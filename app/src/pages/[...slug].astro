---
import Base from "../layouts/Base.astro";
import Sidebar from "../components/Sidebar.astro";
import Toc from "../components/Toc.astro";
import { getPageBySlug, getSidebarPages, type PageRow, type SidebarRow } from "../lib/db/pages";
import { renderMarkdown, extractHeadings } from "../lib/markdown";
import { setReaderCacheHeaders } from "../lib/access";

const slug = Astro.params.slug;
if (!slug) return new Response(null, { status: 404 });

const { db, visitor } = Astro.locals;

let page: PageRow | null;
let navPages: SidebarRow[] = [];
try {
  page = await getPageBySlug(db, slug, visitor);
  navPages = await getSidebarPages(db, visitor);
} catch {
  // FAIL CLOSED: never render content on a backend error.
  return new Response("Service unavailable", { status: 503 });
}

// Not-found AND forbidden both return 404 — no existence signal (red-team R2).
if (!page) return new Response(null, { status: 404 });

setReaderCacheHeaders(Astro.response.headers, page.visibility, visitor);
const html = renderMarkdown(page.body);
const headings = extractHeadings(page.body);
---

<Base title={page.title} visitor={visitor}>
  <div class="doc">
    <Sidebar pages={navPages} current={slug} />
    <article class="prose doc-main">
      <div class="doc-head">
        <h1>{page.title}</h1>
        {
          visitor?.role === "editor" && (
            <a class="edit-btn" href={`/edit-pages/edit/${page.slug}`} title="Edit this page">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                <path d="M11.013 1.427a1.75 1.75 0 0 1 2.474 0l1.086 1.086a1.75 1.75 0 0 1 0 2.474l-8.61 8.61c-.21.21-.47.364-.756.445l-3.251.93a.75.75 0 0 1-.927-.928l.929-3.25c.081-.286.235-.547.445-.758l8.61-8.61Zm.176 4.823L9.75 4.81l-6.286 6.287a.253.253 0 0 0-.064.108l-.558 1.953 1.953-.558a.253.253 0 0 0 .108-.064L11.189 6.25Z" />
              </svg>
              Edit
            </a>
          )
        }
      </div>
      <Fragment set:html={html} />
    </article>
    <Toc headings={headings} />
  </div>
</Base>
