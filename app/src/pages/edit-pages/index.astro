---
import Base from "../../layouts/Base.astro";
import AlertDialog from "../../components/AlertDialog.astro";
import { requireEditor } from "../../lib/auth/requireEditor";
import { isAdminRole } from "../../lib/auth/visitor";
import { issueCsrf } from "../../lib/csrf";
import { listAllPages } from "../../lib/content/pages";
import { isReviewMode, isWritable } from "../../lib/content/store";

const denied = requireEditor(Astro.locals);
if (denied) return denied;

Astro.response.headers.set("Cache-Control", "private, no-store");
Astro.response.headers.set("Vary", "Cookie");

const pages = await listAllPages();
const sections = [...new Set(pages.map((p) => p.section))];
const deleted = Astro.url.searchParams.get("deleted");
const writable = isWritable(Astro.locals.contentStore);
// Always issue CSRF: the New page / Delete controls are live even in
// preview-only (so they hover/look real), and a preview-only delete must reach
// the endpoint's friendly readonly redirect — not a bare 403 for a blank token.
const csrf = issueCsrf(Astro.cookies, Astro.url.protocol === "https:");

// "Submitted for review" banner (PR mode). pr is numeric-validated; the link is
// built from the server-known repo, never from user input.
const submitted = Astro.url.searchParams.get("submitted");
const drafted = Astro.url.searchParams.get("drafted");
const prParam = Astro.url.searchParams.get("pr") ?? "";
const prNumber = /^[0-9]{1,8}$/.test(prParam) ? prParam : null;
const cfg = Astro.locals.contentStore;
const prUrl = prNumber ? `https://github.com/${cfg.github?.repo}/pull/${prNumber}` : null;
const reviewMode = isReviewMode(cfg);
---

<Base title="Editor" visitor={Astro.locals.visitor}>
  <div class="container admin-page" data-readonly={String(!writable)}>
  <div class="admin-head">
    <h1>Pages</h1>
    <div>
      {
        isAdminRole(Astro.locals.visitor?.role) && reviewMode && (
          <a class="btn btn-alt" href="/edit-pages/reviews">Reviews</a>
        )
      }
      <a class="btn btn-brand" href="/edit-pages/create">+ New page</a>
    </div>
  </div>
  <a class="btn-cancel admin-back" href="/" id="admin-back">← Back to handbook</a>
  {deleted && <div class="notice">✓ Page deleted.</div>}
  {
    Astro.url.searchParams.get("error") === "readonly" && (
      <div class="notice notice-warn">⚠ That change can’t be saved in this environment (preview only).</div>
    )
  }
  {
    submitted && prNumber && (
      <div class="notice">
        ✓ <strong>Submitted for approval.</strong> Your change to <code>{submitted}</code> is
        pending (<a href={prUrl} target="_blank" rel="noopener">review #{prNumber}</a>). It goes
        live once an admin approves &amp; publishes it.
      </div>
    )
  }
  {
    drafted && (
      <div class="notice">
        ✓ <strong>Draft saved.</strong> Your work on <code>{drafted}</code> is kept privately (not
        submitted, not visible in the handbook). Open the page again to keep editing, and use
        “Submit for approval” when it's ready.
      </div>
    )
  }

  {
    writable && reviewMode ? (
      <div class="notice">
        ✎ <strong>Draft &amp; review.</strong> “Save draft” keeps work-in-progress private;
        “Submit for approval” sends it to an admin, who publishes it.
      </div>
    ) : writable ? (
      <div class="notice">
        ✎ <strong>Local editing.</strong> Create/edit/delete write markdown files + git commits on
        this machine via the local content agent.
      </div>
    ) : (
      <div class="notice notice-warn">
        ✎ <strong>Preview only.</strong> Editing isn't enabled in this environment — you can open
        and preview pages, but New / Delete return an error. To add, change, or remove a page,
        commit its markdown under <code>app/src/content/pages/</code> (or use an environment with
        editing enabled).
      </div>
    )
  }

  {
    sections.map((section) => {
      const items = pages.filter((p) => p.section === section);
      return (
        <details class="admin-section" open>
          <summary class="admin-section-title">
            {section} <span class="admin-count">{items.length}</span>
          </summary>
          <table class="admin-list">
            <thead>
              <tr>
                <th>Title</th>
                <th class="col-right">Visibility</th>
                <th class="col-right">Actions</th>
              </tr>
            </thead>
            <tbody>
              {items.map((p) => (
                <tr>
                  <td>{p.title}</td>
                  <td class="col-right">
                    <span class={`badge badge-${p.visibility}`}>{p.visibility}</span>
                  </td>
                  <td class="col-right row-actions">
                    <a class="btn-link" href={`/edit-pages/edit/${p.slug}`}>Edit</a>
                    <a class="btn-link" href={`/${p.slug}`}>View</a>
                    <button
                      type="button"
                      class="btn-link-danger row-delete"
                      data-slug={p.slug}
                      data-title={p.title}
                    >
                      Delete
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </details>
      );
    })
  }
  </div>

  <dialog id="del-dialog" class="confirm-dialog">
    <h2>Delete this page?</h2>
    <p>
      Are you sure you want to delete “<strong id="del-title" />”? This cannot be undone.
    </p>
    <form method="POST" action="/edit-pages/delete" id="del-form">
      <input type="hidden" name="csrf" value={csrf} />
      <input type="hidden" name="slug" id="del-slug" />
      <div class="confirm-actions">
        <button type="button" class="btn btn-alt" id="del-cancel">
          Cancel
        </button>
        <button type="submit" class="btn btn-danger">
          Delete page
        </button>
      </div>
    </form>
  </dialog>
  <AlertDialog />
</Base>

<script>
  import { wireBackLink } from "../../lib/ui/backLink";
  wireBackLink("admin-back");

  // Delete: confirmation dialog when editing is enabled; in preview-only, the
  // readonly notice instead of confirming a delete that can't happen.
  const readonly = document.querySelector(".admin-page")?.getAttribute("data-readonly") === "true";
  const showAlert = (msg: string) =>
    document.dispatchEvent(new CustomEvent("app:alert", { detail: msg }));
  const READONLY_MSG =
    "Editing isn't enabled in this environment (preview only). To change the handbook, commit the markdown to the repository — or use an environment with editing enabled.";
  const dialog = document.getElementById("del-dialog") as HTMLDialogElement | null;
  const delForm = document.getElementById("del-form") as HTMLFormElement | null;
  const slugInput = document.getElementById("del-slug") as HTMLInputElement | null;
  const titleEl = document.getElementById("del-title");
  for (const btn of document.querySelectorAll<HTMLButtonElement>(".row-delete")) {
    btn.addEventListener("click", () => {
      if (readonly) return showAlert(READONLY_MSG);
      if (slugInput) slugInput.value = btn.dataset.slug ?? "";
      if (titleEl) titleEl.textContent = btn.dataset.title ?? "this page";
      dialog?.showModal();
    });
  }
  document.getElementById("del-cancel")?.addEventListener("click", () => dialog?.close());
  // Submit delete via fetch so a server error pops up instead of a raw page.
  delForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    dialog?.close();
    try {
      const res = await fetch(delForm.action, {
        method: "POST",
        body: new FormData(delForm),
        headers: { "X-Requested-With": "fetch" },
      });
      if (res.ok) return void (window.location.href = res.url);
      showAlert((await res.text().catch(() => "")) || `Couldn't delete (error ${res.status}).`);
    } catch {
      showAlert("Couldn't reach the server — check your connection and try again.");
    }
  });
</script>
