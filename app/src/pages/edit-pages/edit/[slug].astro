---
import Base from "../../../layouts/Base.astro";
import EditorForm from "../../../components/EditorForm.astro";
import { requireEditor } from "../../../lib/auth/requireEditor";
import { issueCsrf } from "../../../lib/csrf";
import { listGroups, getPageGroupKeys } from "../../../lib/db/groups";
import { getEditablePageBySlug, listAllPages } from "../../../lib/db/pages";

const denied = requireEditor(Astro.locals);
if (denied) return denied;

Astro.response.headers.set("Cache-Control", "private, no-store");
Astro.response.headers.set("Vary", "Cookie");

const slug = Astro.params.slug;
const page = slug ? await getEditablePageBySlug(Astro.locals.db, slug) : null;
if (!page) return new Response(null, { status: 404 });

const pageGroupKeys = await getPageGroupKeys(Astro.locals.db, page.id);
const csrf = issueCsrf(Astro.cookies, Astro.url.protocol === "https:");
const groups = await listGroups(Astro.locals.db);
const sections = [...new Set((await listAllPages(Astro.locals.db)).map((p) => p.section))];

// Confirmation after a save (set by /edit-pages/save).
const saved = Astro.url.searchParams.get("saved");
const savedMsg = saved === "published" ? "Published" : saved === "draft" ? "Saved as draft" : null;
---

<Base title={`Edit: ${page.title}`} visitor={Astro.locals.visitor}>
  <div class="container editor-page">
    <h1>Edit: {page.title}</h1>
    {
      savedMsg && (
        <div class="notice">
          ✓ {savedMsg}.{" "}
          {page.status === "published" ? (
            <a href={`/${page.slug}`}>View page →</a>
          ) : (
            <span class="notice-muted">(draft — not visible to readers yet)</span>
          )}
        </div>
      )
    }
    <EditorForm page={page} pageGroupKeys={pageGroupKeys} csrf={csrf} groups={groups} sections={sections} />
  </div>
</Base>
