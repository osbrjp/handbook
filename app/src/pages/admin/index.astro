---
import Base from "../../layouts/Base.astro";
import { requireEditor } from "../../lib/auth/requireEditor";
import { issueCsrf } from "../../lib/csrf";
import { listAllPages } from "../../lib/db/pages";

const denied = requireEditor(Astro.locals);
if (denied) return denied;

Astro.response.headers.set("Cache-Control", "private, no-store");
Astro.response.headers.set("Vary", "Cookie");

const pages = await listAllPages(Astro.locals.db);
const sections = [...new Set(pages.map((p) => p.section))];
const deleted = Astro.url.searchParams.get("deleted");
const csrf = issueCsrf(Astro.cookies, Astro.url.protocol === "https:");
---

<Base title="Editor" visitor={Astro.locals.visitor}>
  <div class="container admin-page">
  <a class="btn-cancel" href="/" id="admin-back" style="display:inline-block;margin-bottom:1rem"
    >← Back to handbook</a
  >
  <div class="admin-head">
    <h1>Pages</h1>
    <a class="btn btn-brand" href="/admin/new">+ New page</a>
  </div>
  {deleted && <div class="notice">✓ Page deleted.</div>}

  {
    sections.map((section) => {
      const items = pages.filter((p) => p.section === section);
      return (
        <details class="admin-section" open>
          <summary class="admin-section-title">
            {section} <span class="admin-count">{items.length}</span>
          </summary>
          <table class="admin-list">
            <thead>
              <tr>
                <th>Title</th>
                <th class="col-right">Visibility</th>
                <th class="col-right">Status</th>
                <th class="col-right">Actions</th>
              </tr>
            </thead>
            <tbody>
              {items.map((p) => (
                <tr>
                  <td>{p.title}</td>
                  <td class="col-right">
                    <span class={`badge badge-${p.visibility}`}>{p.visibility}</span>
                  </td>
                  <td class="col-right">{p.status}</td>
                  <td class="col-right row-actions">
                    <a href={`/admin/edit/${p.id}`}>Edit</a>
                    <a href={`/${p.slug}`}>View</a>
                    <button type="button" class="row-delete" data-id={p.id} data-title={p.title}>
                      Delete
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </details>
      );
    })
  }
  </div>

  <dialog id="del-dialog" class="confirm-dialog">
    <h2>Delete this page?</h2>
    <p>
      Are you sure you want to delete “<strong id="del-title"></strong>”? This cannot be undone.
    </p>
    <form method="POST" action="/admin/delete" id="del-form">
      <input type="hidden" name="csrf" value={csrf} />
      <input type="hidden" name="id" id="del-id" />
      <div class="confirm-actions">
        <button type="button" class="btn btn-alt" id="del-cancel">Cancel</button>
        <button type="submit" class="btn btn-danger">Delete page</button>
      </div>
    </form>
  </dialog>
</Base>

<script>
  const dialog = document.getElementById("del-dialog") as HTMLDialogElement | null;
  const idInput = document.getElementById("del-id") as HTMLInputElement | null;
  const titleEl = document.getElementById("del-title");
  for (const btn of document.querySelectorAll<HTMLButtonElement>(".row-delete")) {
    btn.addEventListener("click", () => {
      if (idInput) idInput.value = btn.dataset.id ?? "";
      if (titleEl) titleEl.textContent = btn.dataset.title ?? "this page";
      dialog?.showModal();
    });
  }
  document.getElementById("del-cancel")?.addEventListener("click", () => dialog?.close());

  // Back returns to the previous page (last state), falling back to the
  // handbook home (href="/") for direct loads / off-site referrers.
  const backLink = document.getElementById("admin-back");
  backLink?.addEventListener("click", (e) => {
    let sameOrigin = false;
    try {
      sameOrigin = !!document.referrer && new URL(document.referrer).origin === location.origin;
    } catch {
      sameOrigin = false;
    }
    if (window.history.length > 1 && sameOrigin) {
      e.preventDefault();
      history.back();
    }
  });
</script>
