---
import Base from "../../../layouts/Base.astro";
import EditorForm from "../../../components/EditorForm.astro";
import { requireEditor } from "../../../lib/auth/requireEditor";
import { issueCsrf } from "../../../lib/csrf";
import { listGroups, getPageGroupKeys } from "../../../lib/db/groups";
import { getPageById, listAllPages } from "../../../lib/db/pages";

const denied = requireEditor(Astro.locals);
if (denied) return denied;

Astro.response.headers.set("Cache-Control", "private, no-store");
Astro.response.headers.set("Vary", "Cookie");

const id = Number(Astro.params.id);
const page = Number.isFinite(id) ? await getPageById(Astro.locals.db, id) : null;
if (!page) return new Response(null, { status: 404 });

const pageGroupKeys = await getPageGroupKeys(Astro.locals.db, id);
const csrf = issueCsrf(Astro.cookies, Astro.url.protocol === "https:");
const groups = await listGroups(Astro.locals.db);
const sections = [...new Set((await listAllPages(Astro.locals.db)).map((p) => p.section))];
---

<Base title={`Edit: ${page.title}`} visitor={Astro.locals.visitor}>
  <div class="container">
    <h1>Edit page</h1>
    <EditorForm page={page} pageGroupKeys={pageGroupKeys} csrf={csrf} groups={groups} sections={sections} />
  </div>
</Base>
