# Copy to app/.env for local dev.

# Directus URL the BROWSER and Google OAuth redirects use.
PUBLIC_DIRECTUS_URL=http://localhost:8055

# Directus URL the Astro SERVER uses for SSR fetches.
# Same as above when the app runs on the host (pnpm dev).
# If you run the app INSIDE docker compose, set this to http://directus:8055.
DIRECTUS_INTERNAL_URL=http://localhost:8055

# Public base URL of THIS app (used to build the OAuth callback).
PUBLIC_APP_URL=http://localhost:4321
